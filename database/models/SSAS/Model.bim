        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/(localdb)\\MSSQLLocalDB;supply_chain_dw\",",
                "    dbo_fact_supply_chain = Source{[Schema=\"dbo\",Item=\"fact_supply_chain\"]}[Data]",
                "in",
                "    dbo_fact_supply_chain"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Total Units Sold",
            "expression": "sum(fact_supply_chain[units_sold])",
            "displayFolder": "Sales KPIs"
          },
          {
            "name": "Total Inventory",
            "expression": " SUM(fact_supply_chain[inventory_level])",
            "displayFolder": "Inventory KPIs"
          },
          {
            "name": "Stockout Count",
            "expression": " SUM(fact_supply_chain[stockout_flag])",
            "formatString": "0",
            "displayFolder": "Inventory KPIs"
          },
          {
            "name": "Total Revenue",
            "expression": " SUMX(fact_supply_chain, fact_supply_chain[units_sold] * fact_supply_chain[unit_price])",
            "formatString": "0",
            "displayFolder": "Sales KPIs"
          },
          {
            "name": "Total Cost",
            "expression": " SUMX(fact_supply_chain, fact_supply_chain[units_sold] * fact_supply_chain[unit_cost])",
            "formatString": "0",
            "displayFolder": "Sales KPIs"
          },
          {
            "name": "Profit",
            "expression": " [Total Revenue] - [Total Cost]",
            "formatString": "0.00",
            "displayFolder": "Sales KPIs"
          },
          {
            "name": "Profit Margin",
            "expression": " DIVIDE([Profit], [Total Revenue])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales KPIs"
          },
          {
            "name": "Total Sales",
            "expression": [
              " ",
              "SUMX(",
              "    fact_supply_chain,",
              "    fact_supply_chain[units_sold] * fact_supply_chain[unit_price]",
              ")"
            ]
          },
          {
            "name": "Avg Lead Time",
            "expression": [
              "",
              "AVERAGE(fact_supply_chain[supplier_lead_time_days])"
            ],
            "formatString": "0.00"
          },
          {
            "name": "Low Stock Count",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(fact_supply_chain),",
              "    fact_supply_chain[inventory_level] < fact_supply_chain[reorder_point]",
              ")"
            ]
          },
          {
            "name": "Revenue per Unit",
            "expression": [
              "",
              "DIVIDE([Total Revenue], [Total Units Sold])"
            ],
            "formatString": "0.00"
          }
        ]
      }
    ],
