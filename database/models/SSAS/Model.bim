        "name": "dim_date",
        "columns": [
          {
            "name": "date_key",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "date_key",
            "sortByColumn": "Month Number"
          },
          {
            "name": "full_date",
            "dataType": "dateTime",
            "sourceColumn": "full_date"
          },
          {
            "type": "calculated",
            "name": "Year",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "expression": " YEAR(dim_date[full_date])"
          },
          {
            "type": "calculated",
            "name": "Month Number",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "expression": " MONTH(dim_date[full_date])"
          },
          {
            "type": "calculated",
            "name": "Month Name",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": " FORMAT(dim_date[full_date], \"MMMM\")",
            "sortByColumn": "Month Number"
          },
          {
            "type": "calculated",
            "name": "Quarter",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": " \"Q\" & FORMAT(dim_date[full_date], \"Q\")"
          },
          {
            "type": "calculated",
            "name": "Day",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "expression": " DAY(dim_date[full_date])"
          }
        ],
